# VibeVoice TTS Server Configuration
# All settings use the VIBEVOICE_TTS_ prefix

# VIBEVOICE_TTS_HOST=0.0.0.0
# VIBEVOICE_TTS_PORT=8100
# VIBEVOICE_TTS_MODEL_ID=vibevoice/VibeVoice-7B
# VIBEVOICE_TTS_CACHE_DIR=
# VIBEVOICE_TTS_DEVICE=auto
# VIBEVOICE_TTS_DTYPE=auto
# VIBEVOICE_TTS_IDLE_TIMEOUT=300
# VIBEVOICE_TTS_DEFAULT_VOICE=alloy
# VIBEVOICE_TTS_CFG_SCALE=1.3
# VIBEVOICE_TTS_N_DIFFUSION_STEPS=10
# VIBEVOICE_TTS_MAX_NEW_TOKENS=0  # 0=unlimited; tokens are audio frames at 7.5 Hz (20250 ≈ 45 min)
# VIBEVOICE_TTS_QUANTIZE_4BIT=false
# VIBEVOICE_TTS_LOG_LEVEL=info
